# Root .gitignore — covers project-level artifacts not in sub-directories.

# OS artifacts
.DS_Store
Thumbs.db
desktop.ini

# Windows reserved device name artifacts (created accidentally by redirects)
nul

# Dev server runtime
.server-port

# Temporary directories
temp/

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# AI assistant artifacts
.claude/
.codex/
# Agent skills setup (/setup-matt-pocock-skills) — local engineering-skill config, not app code
AGENTS.md
docs/agents/

# Tauri updater signing keys (NEVER commit these)
*.tauri.key
pianotoy.key
src-tauri/*.key

# Tauri build output
desktop/src-tauri/target/
desktop/src-tauri/gen/
